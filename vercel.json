{
    "version": 2,
    "framework": "vite",
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "installCommand": "npm install",
    "functions": {
        "api/index.py": {
            "maxDuration": 60
        }
    },
    "rewrites": [{
        "source": "/api/(.*)",
        "destination": "/api/index.py"
    }]
}